page {
  --bg: #f5f5f5;
  --card: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --primary: #e74c3c;
  --primary-light: #fde8e5;
  --accent: #f39c12;
  --win: #e74c3c;
  --lose: #27ae60;
  --kda: #3498db;
  --muted: #95a5a6;

  background: var(--bg);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-muted);
  font-size: 28rpx;
}
