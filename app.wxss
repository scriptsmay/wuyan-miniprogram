page {
  --bg: #0a0e1a;
  --card: #11151f;
  --card-elevated: #1a1f2a;
  --text: #ffffff;
  --text-secondary: #b0b3c0;
  --text-muted: #6b6f7a;
  --primary: #00d4ff;
  --primary-dark: #0099cc;
  --primary-glow: rgba(0, 212, 255, 0.3);
  --secondary: #ff9f4d;
  --border: rgba(255, 255, 255, 0.08);
  --win: #00d4ff;
  --lose: #ff9f4d;
  --kda: #00d4ff;
  --muted: #6b6f7a;

  background: var(--bg);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-muted);
  font-size: 28rpx;
}
