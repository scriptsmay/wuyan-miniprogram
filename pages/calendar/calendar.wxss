.summary-card {
  background: linear-gradient(135deg, #2c3e50, #34495e);
  color: #fff;
}

.month-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.summary-grid {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f39c12;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

.stream-list {
  margin-top: 4rpx;
}

.stream-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stream-item:last-child {
  border-bottom: none;
}

.stream-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stream-date {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 140rpx;
}

.stream-time {
  font-size: 24rpx;
  color: #999;
}

.stream-duration {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: 600;
}
