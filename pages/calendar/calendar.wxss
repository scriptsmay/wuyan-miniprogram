.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-bottom: 8rpx;
  gap: 40rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  transition: all 0.15s;
}

.nav-btn:active {
  background: #f0f0f0;
  transform: scale(0.94);
}

.nav-arrow {
  font-size: 28rpx;
  color: #e74c3c;
}

.nav-btn-placeholder {
  opacity: 0;
  pointer-events: none;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  min-width: 200rpx;
  text-align: center;
}

.nav-loading {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
}

.summary-card {
  background: linear-gradient(135deg, #2c3e50, #34495e);
  color: #fff;
}

.summary-grid {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f39c12;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

.stream-list {
  margin-top: 4rpx;
}

.stream-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stream-item:last-child {
  border-bottom: none;
}

.stream-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stream-date {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 140rpx;
}

.stream-time {
  font-size: 24rpx;
  color: #999;
}

.stream-duration {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: 600;
}
