.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-bottom: 8rpx;
  gap: 40rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--card);
  border: 1rpx solid var(--border);
  transition: all 0.15s;
}

.nav-btn:active {
  background: var(--card-elevated);
  transform: scale(0.94);
}

.nav-arrow {
  font-size: 28rpx;
  color: var(--primary);
}

.nav-btn-placeholder {
  opacity: 0;
  pointer-events: none;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  min-width: 200rpx;
  text-align: center;
}

.nav-loading {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 400;
}

.summary-card {
  background: linear-gradient(135deg, rgba(0,212,255,0.08), rgba(0,212,255,0.02));
  border-color: rgba(0, 212, 255, 0.15);
}

.summary-grid {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.stream-list {
  margin-top: 4rpx;
}

.stream-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.stream-item:last-child {
  border-bottom: none;
}

.stream-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stream-date {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  min-width: 140rpx;
}

.stream-time {
  font-size: 24rpx;
  color: var(--text-muted);
}

.stream-duration {
  font-size: 28rpx;
  color: var(--secondary);
  font-weight: 600;
}
