.hero-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.hero-item:last-child {
  border-bottom: none;
}

.hero-rank {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: var(--card-elevated);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hero-item:first-child .hero-rank { background: var(--primary); color: #0a0e1a; }
.hero-item:nth-child(2) .hero-rank { background: var(--secondary); color: #fff; }
.hero-item:nth-child(3) .hero-rank { background: #0099cc; color: #fff; }

.hero-info {
  flex: 1;
}

.hero-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.hero-bar-wrap {
  height: 8rpx;
  background: var(--card-elevated);
  border-radius: 4rpx;
  overflow: hidden;
}

.hero-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 4rpx;
  transition: width 0.3s;
}

.hero-meta {
  text-align: right;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.hero-battles {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
}

.hero-winrate {
  font-size: 28rpx;
  font-weight: 600;
}

.hero-winrate.win-high { color: var(--primary); }
.hero-winrate.win-mid { color: var(--secondary); }
.hero-winrate.win-low { color: var(--text-muted); }
