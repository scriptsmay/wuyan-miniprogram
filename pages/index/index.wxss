.season-card {
  background: linear-gradient(135deg, #0a0e1a, #1a2a3a);
  border-color: rgba(0, 212, 255, 0.1);
  color: #fff;
}

.season-card .card-title { display: none; }

.season-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.player-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.team-tag {
  font-size: 24rpx;
  background: rgba(0, 212, 255, 0.15);
  color: var(--secondary);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.season-subtitle {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 28rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.stat-value.highlight { color: var(--primary); }
.stat-value.kda { color: var(--primary); }
.stat-value.accent { color: var(--secondary); }

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.sub-stats {
  display: flex;
  justify-content: space-around;
}

.sub-stat {
  text-align: center;
}

.sub-stat-val {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--secondary);
}

.sub-stat-label {
  font-size: 20rpx;
  color: var(--text-muted);
}

.hero-list {
  margin-top: 4rpx;
}

.hero-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.hero-item:last-child {
  border-bottom: none;
}

.hero-rank {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: var(--card-elevated);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-right: 16rpx;
}

.hero-item:first-child .hero-rank { background: var(--primary); color: #0a0e1a; }
.hero-item:nth-child(2) .hero-rank { background: var(--secondary); color: #fff; }
.hero-item:nth-child(3) .hero-rank { background: #0099cc; color: #fff; }

.hero-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.hero-battles {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-right: 16rpx;
}

.hero-winrate {
  font-size: 28rpx;
  font-weight: 600;
}

.hero-winrate.win-high { color: var(--primary); }
.hero-winrate.win-mid { color: var(--secondary); }
.hero-winrate.win-low { color: var(--text-muted); }

.card-footer {
  text-align: center;
  color: var(--primary);
  font-size: 26rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.live-card {
  background: linear-gradient(135deg, #11151f, #1a1f2a);
  border-color: rgba(0, 212, 255, 0.12);
  color: #fff;
}

.live-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.live-card-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: var(--secondary);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.live-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 8rpx;
}

.live-stat {
  text-align: center;
}

.live-stat-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.live-stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.live-placeholder {
  text-align: center;
  padding: 30rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}
